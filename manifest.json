{
  "manifest_version": 3,
  "name": "QA Test Case Generator",
  "description": "Generate QA test cases from requirement text",
  "version": "1.1",
  "permissions": ["activeTab", "scripting", "contextMenus", "storage"],
  "host_permissions": ["http://localhost:3000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
